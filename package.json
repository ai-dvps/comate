{
  "name": "comate",
  "version": "0.0.25",
  "description": "Your friendly AI workspace companion",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "tsc -b && vite build && npm run build:cli",
    "build:server": "tsc -p tsconfig.server.json",
    "build:cli": "npm run build -w packages/wecom-cli",
    "build:sidecar": "tsx scripts/build-sidecar.ts",
    "build:steel": "tsx scripts/build-steel-bundle.ts",
    "start": "node dist/server/index.js",
    "test:client": "vitest run --project jsdom",
    "test:client:watch": "vitest --project jsdom",
    "test:browser": "vitest run --project browser",
    "test:server": "tsx --test-isolation=process --test-concurrency=1 -r ./src/server/test-utils/test-env.ts --test --test-force-exit $(find src/server -name '*.test.ts' -not -path '*/vendor/*')",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "release": "npm run build:sidecar && npm run tauri:build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.217",
    "@chat-adapter/state-memory": "^4.31.0",
    "@codemirror/commands": "^6.6.2",
    "@codemirror/lang-cpp": "^6.0.2",
    "@codemirror/lang-css": "^6.3.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-java": "^6.0.1",
    "@codemirror/lang-javascript": "^6.2.2",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.2.5",
    "@codemirror/lang-php": "^6.0.1",
    "@codemirror/lang-python": "^6.1.6",
    "@codemirror/lang-rust": "^6.0.1",
    "@codemirror/lang-sql": "^6.7.1",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.1",
    "@codemirror/language": "^6.10.2",
    "@codemirror/merge": "^6.7.0",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.28.4",
    "@larksuite/vercel-chat-adapter": "^0.1.2",
