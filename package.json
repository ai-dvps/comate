{
  "name": "claude-code-gui",
  "version": "1.0.0",
  "description": "Personal workspace manager and GUI for Claude Code",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run generate:skills && tsc -b && vite build && npm run build:cli",
    "build:server": "npm run generate:skills && tsc -p tsconfig.server.json",
    "build:cli": "npm run build -w packages/wecom-cli",
    "generate:skills": "tsx scripts/generate-wecom-skill.ts",
    "build:sidecar": "tsx scripts/build-sidecar.ts",
    "start": "node dist/server/index.js",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "release": "npm run build:sidecar && npm run tauri:build"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.144",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-use-controllable-state": "^1.1.0",
    "@tanstack/react-virtual": "^3.13.25",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@vscode/ripgrep": "^1.18.0",
    "@webank/wecom": "workspace:*",
    "@wecom/aibot-node-sdk": "^1.0.7",
    "better-sqlite3": "^12.10.0",
    "chokidar": "^5.0.0",
    "clsx": "^2.0.0",
    "cors": "^2.8.5",
    "dompurify": "^3.4.4",
    "express": "^4.19.2",
    "fdir": "^6.5.0",
    "fuzzysort": "^3.1.0",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "ignore": "^7.0.5",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "shiki": "^1.0.0",
    "streamdown": "^1.0.0",
    "tailwind-merge": "^2.0.0",
    "use-stick-to-bottom": "^1.0.0",
    "uuid": "^9.0.1",
    "ws": "^8.20.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.12.0",
    "@typescript-eslint/parser": "^7.12.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@yao-pkg/pkg": "^6.19.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.11.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.13"
  }
}
