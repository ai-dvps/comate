---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import LanguagePicker from '../../components/LanguagePicker.astro';
import { useTranslations } from '../../i18n/utils.js';

const locale = 'zh';
const t = useTranslations(locale);
---

<BaseLayout title="Comate" description="您的智能桌面 AI 工作伙伴">
  <Nav>
    <LanguagePicker slot="language-picker" />
    <LanguagePicker slot="language-picker-mobile" />
  </Nav>

  <main class="mx-auto max-w-5xl px-4 py-12">
    <h1 class="text-4xl font-bold text-text-primary">Comate</h1>
    <p class="mt-4 text-lg text-text-secondary">{t('nav.home')}</p>
  </main>

  <Footer />
</BaseLayout>
