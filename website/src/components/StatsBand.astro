---
interface Props {
  stats: Array<{ label: string; value: string; icon?: string }>;
}

const { stats } = Astro.props;

const icons: Record<string, string> = {
  'open-source': 'M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  ai: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20Zm0 18a8 8 0 1 1 0-16 8 8 0 0 1 0 16Zm-1-13h2v5h-2Zm0 7h2v2h-2',
  desktop:
    'M20 16V7a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v9m16 0H4m16 0 1.5 3H2.5L4 16',
  bot: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2 M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M23 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75',
};
---

<div class="mx-auto max-w-6xl px-4">
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {
      stats.map((stat) => (
        <div class="reveal flex items-center gap-4 rounded-xl border border-border bg-surface p-4 shadow-sm transition-all duration-200 hover:border-border-hover hover:shadow-md">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-accent/10 text-accent">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={icons[stat.icon ?? ''] ?? icons['open-source']} />
            </svg>
          </div>
          <div>
            <p class="text-lg font-semibold text-text-primary">{stat.value}</p>
            <p class="text-sm text-text-secondary">{stat.label}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>
