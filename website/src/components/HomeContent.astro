---
import { getCollection, render } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getContentLocale, type Lang } from '../i18n/utils.js';

interface Props {
  locale: Lang;
}

const { locale } = Astro.props;
const contentLocale = getContentLocale(locale).toLowerCase();
const entries = await getCollection('home');
const entry =
  entries.find((e) => e.id === `${contentLocale}/hero`) ??
  entries.find((e) => e.id === `zh-cn/hero`);
if (!entry) {
  throw new Error(`Missing hero content for locale ${locale}`);
}
const { Content } = await render(entry);
const { title, description, ctaText, ctaHref } = entry.data;
---

<section class="mx-auto max-w-5xl px-4 py-16 md:py-24">
  <div class="flex flex-col items-start gap-6">
    <h1 class="text-4xl font-bold tracking-tight text-text-primary md:text-6xl">
      {title}
    </h1>
    <p class="max-w-2xl text-lg text-text-secondary md:text-xl">
      {description}
    </p>
    <div class="mt-2 max-w-2xl text-text-secondary">
      <Content />
    </div>
    <a
      href={getRelativeLocaleUrl(locale, ctaHref)}
      class="mt-4 inline-flex items-center rounded-md bg-accent px-6 py-3 text-base font-medium text-accent-foreground no-underline shadow-sm hover:bg-accent-hover focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
    >
      {ctaText}
    </a>
  </div>
</section>
