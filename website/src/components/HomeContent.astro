---
import { getCollection, render } from 'astro:content';
import { getContentLocale, getLocalizedEntries, type Lang } from '../i18n/utils.js';
import HeroSection from './HeroSection.astro';
import StatsBand from './StatsBand.astro';
import FeatureHighlightGrid from './FeatureHighlightGrid.astro';
import BeforeAfterStrip from './BeforeAfterStrip.astro';
import CTASection from './CTASection.astro';

interface Props {
  locale: Lang;
}

const { locale } = Astro.props;
const contentLocale = getContentLocale(locale).toLowerCase();

const homeEntries = await getCollection('home');
const homeEntry =
  homeEntries.find((e) => e.id === `${contentLocale}/hero`) ??
  homeEntries.find((e) => e.id === `zh-cn/hero`);
if (!homeEntry) {
  throw new Error(`Missing hero content for locale ${locale}`);
}
const { Content } = await render(homeEntry);
const { title, description, headline, subheadline, ctaText, ctaHref, secondaryCtaText, secondaryCtaHref, stats } =
  homeEntry.data;

const allFeatures = await getCollection('features');
const features = getLocalizedEntries(allFeatures, locale)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 6)
  .map((entry) => ({ ...entry.data }));
---

<div class="space-y-4">
  <HeroSection
    locale={locale}
    headline={headline ?? title}
    subheadline={subheadline ?? description}
    ctaText={ctaText}
    ctaHref={ctaHref}
    secondaryCtaText={secondaryCtaText}
    secondaryCtaHref={secondaryCtaHref}
  />

  {stats && stats.length > 0 && <StatsBand stats={stats} />}

  <FeatureHighlightGrid locale={locale} features={features} />

  <BeforeAfterStrip locale={locale} />

  <CTASection locale={locale} />

  <section class="mx-auto max-w-3xl px-4 pb-16 text-center text-text-tertiary">
    <Content />
  </section>
</div>
