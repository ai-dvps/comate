---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Lang } from '../i18n/utils.js';
import DemoMockup from './DemoMockup.astro';

interface Props {
  locale: Lang;
  headline: string;
  subheadline: string;
  ctaText: string;
  ctaHref: string;
  secondaryCtaText?: string;
  secondaryCtaHref?: string;
}

const { locale, headline, subheadline, ctaText, ctaHref, secondaryCtaText, secondaryCtaHref } = Astro.props;
const t = useTranslations(locale);
---

<section class="relative overflow-hidden px-4 pt-16 pb-20 md:pt-24 md:pb-32">
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-40 dark:opacity-30"
    aria-hidden="true"
  >
    <div
      class="absolute -top-1/2 left-1/2 h-[600px] w-[800px] -translate-x-1/2 rounded-full bg-accent/20 blur-[120px]"
    >
    </div>
    <div
      class="absolute top-1/3 right-0 h-[400px] w-[500px] translate-x-1/3 rounded-full bg-accent-secondary/10 blur-[100px]"
    >
    </div>
  </div>

  <div class="mx-auto max-w-6xl">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col items-start gap-6">
        <div class="inline-flex items-center gap-2 rounded-full border border-border bg-surface px-3 py-1 text-sm text-text-secondary shadow-sm">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-success opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-success"></span>
          </span>
          {t('home.trustBadge')}
        </div>

        <h1 class="text-balance text-4xl font-bold tracking-tight text-text-primary md:text-5xl lg:text-6xl">
          {headline}
        </h1>

        <p class="text-balance text-lg text-text-secondary md:text-xl">
          {subheadline}
        </p>

        <div class="mt-2 flex flex-wrap items-center gap-4">
          <a
            href={getRelativeLocaleUrl(locale, ctaHref)}
            class="inline-flex min-h-12 items-center justify-center rounded-lg bg-accent px-6 py-3 text-base font-semibold text-accent-foreground no-underline shadow-lg shadow-accent/20 hover:bg-accent-hover hover:shadow-accent/30 focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
          >
            {ctaText}
          </a>
          {
            secondaryCtaText && secondaryCtaHref && (
              <a
                href={getRelativeLocaleUrl(locale, secondaryCtaHref)}
                class="inline-flex min-h-12 items-center justify-center rounded-lg border border-border bg-surface px-6 py-3 text-base font-semibold text-text-primary no-underline hover:border-border-hover hover:bg-surface-hover focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
              >
                {secondaryCtaText}
              </a>
            )
          }
        </div>
      </div>

      <div class="reveal">
        <DemoMockup locale={locale} />
      </div>
    </div>
  </div>
</section>
