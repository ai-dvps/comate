---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, type Lang } from '../i18n/utils.js';

interface Props {
  locale: Lang;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
---

<section class="reveal mx-auto max-w-6xl px-4 py-16 md:py-24">
  <div class="relative overflow-hidden rounded-2xl bg-surface px-6 py-12 text-center md:px-12 md:py-16">
    <div
      class="pointer-events-none absolute inset-0 -z-10 opacity-40 dark:opacity-30"
      aria-hidden="true"
    >
      <div class="absolute left-1/2 top-0 h-[300px] w-[500px] -translate-x-1/2 rounded-full bg-accent/20 blur-[100px]"
      ></div>
    </div>

    <h2 class="mx-auto max-w-2xl text-3xl font-bold tracking-tight text-text-primary md:text-4xl">
      {t('cta.headline')}
    </h2>

    <p class="mx-auto mt-4 max-w-xl text-lg text-text-secondary">
      {t('cta.description')}
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href={getRelativeLocaleUrl(locale, '/download/')}
        class="inline-flex min-h-12 items-center justify-center rounded-lg bg-accent px-8 py-3 text-base font-semibold text-accent-foreground no-underline shadow-lg shadow-accent/20 hover:bg-accent-hover hover:shadow-accent/30"
      >
        {t('nav.downloadCta')}
      </a>
      <a
        href={getRelativeLocaleUrl(locale, '/faq/')}
        class="inline-flex min-h-12 items-center justify-center rounded-lg border border-border bg-bg px-8 py-3 text-base font-semibold text-text-primary no-underline hover:border-border-hover hover:bg-surface-hover"
      >
        {t('nav.faq')}
      </a>
    </div>
  </div>
</section>
