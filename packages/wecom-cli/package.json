{
  "name": "@webank/wecom",
  "version": "0.0.2",
  "description": "CLI for sending WeCom messages via the Comate server",
  "type": "module",
  "bin": {
    "wecom": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.js --banner:js='#!/usr/bin/env node'",
    "test": "node --test dist/test/**/*.test.js"
  },
  "oclif": {
    "commands": {
      "strategy": "explicit",
      "target": "./dist/index.js",
      "identifier": "COMMANDS"
    }
  },
  "dependencies": {
    "@oclif/core": "^4.2.10"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
