{
  "name": "@webank/wecom",
  "version": "1.0.1",
  "description": "CLI for sending WeCom messages via the Comate server",
  "type": "module",
  "bin": {
    "wecom": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test test/**/*.test.js"
  },
  "oclif": {
    "commands": {
      "strategy": "explicit",
      "target": "./dist/index.js",
      "identifier": "COMMANDS"
    }
  },
  "dependencies": {
    "@oclif/core": "^4.2.10"
  },
  "devDependencies": {
    "typescript": "^5.4.5"
  }
}
