{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Comate",
  "version": "0.0.11",
  "identifier": "com.comate.app",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:client",
    "beforeBuildCommand": "npm run build && npm run build:sidecar"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Comate",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:*; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "msi", "app"],
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/sidecar-node"
    ],
    "resources": {
      "resources": "./resources"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5QUU3MTM0MEQ5MDM1NzYKUldSMk5aQU5OSEd1bVZlNGZuaGx1c0NKZHB4SG9EWTlzaTlLeXdndm13bEZ5QXhHclpZYUhSQ2wK",
      "endpoints": [
        "https://github.com/ai-dvps/comate/releases/latest/download/latest.json"
      ],
      "checkOnStartup": false
    }
  }
}
